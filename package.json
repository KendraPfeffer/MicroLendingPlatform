{
  "name": "privacy-micro-lending",
  "private": true,
  "version": "1.0.0",
  "description": "Privacy-first micro-lending platform powered by Zama FHE technology with full-stack development support",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts",
    "deploy:sepolia": "cross-env HARDHAT_NETWORK=sepolia hardhat run scripts/deploy.ts --network sepolia",
    "deploy:localhost": "cross-env HARDHAT_NETWORK=localhost hardhat run scripts/deploy.ts --network localhost",
    "deploy:zama": "cross-env HARDHAT_NETWORK=zamaDevnet hardhat run scripts/deploy.ts --network zamaDevnet",
    "node": "hardhat node",
    "verify": "hardhat verify",
    "coverage": "hardhat coverage",
    "gas-report": "cross-env REPORT_GAS=true hardhat test",
    "clean": "hardhat clean && rm -rf dist",
    "typechain": "hardhat typechain",
    "size": "hardhat size-contracts",
    "start": "npm run dev"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "ethers": "6.13.2"
  },
  "devDependencies": {
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@typescript-eslint/eslint-plugin": "7.2.0",
    "@typescript-eslint/parser": "7.2.0",
    "@vitejs/plugin-react": "4.2.1",
    "eslint": "8.57.0",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-react-refresh": "0.4.6",
    "typescript": "5.2.2",
    "vite": "5.2.0",
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@nomicfoundation/hardhat-ethers": "3.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "2.0.0",
    "@typechain/hardhat": "9.1.0",
    "@typechain/ethers-v6": "0.5.1",
    "@fhevm/solidity": "0.7.0",
    "@fhevm/hardhat-plugin": "0.0.1-3",
    "hardhat": "2.24.3",
    "hardhat-gas-reporter": "1.0.8",
    "solidity-coverage": "0.8.12",
    "hardhat-contract-sizer": "2.10.0",
    "chai": "4.3.10",
    "dotenv": "16.4.5",
    "cross-env": "7.0.3",
    "@types/node": "20.11.24",
    "@types/mocha": "10.0.6",
    "@types/chai": "4.3.11",
    "ts-node": "10.9.2",
    "typechain": "8.3.2"
  },
  "keywords": [
    "blockchain",
    "lending",
    "privacy",
    "fhe",
    "zama",
    "p2p",
    "defi",
    "react",
    "typescript",
    "vite",
    "hardhat",
    "solidity",
    "ethereum"
  ],
  "author": "Privacy Micro-Lending Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/privacy-micro-lending.git"
  },
  "homepage": "https://privacy-micro-lending.vercel.app",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}